# Day 01 示例配置文件
#
# 这个文件只做示例，不放真实 API Key。
# 本地开发时复制一份叫 .env，然后在 .env 里填写真实值。

DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
APP_NAME=day04-ai-service
APP_HOST=127.0.0.1
APP_PORT=8000

# Celery 企业异步任务配置。
# RabbitMQ 作为 Broker，负责真正的消息投递与消费。
RABBITMQ_URL=amqp://python_ai:python_ai_123@127.0.0.1:5672//
CELERY_BROKER_URL=amqp://python_ai:python_ai_123@127.0.0.1:5672//
ASYNC_TASK_TIMEOUT_MINUTES=10
ASYNC_TASK_MAX_RETRIES=3
